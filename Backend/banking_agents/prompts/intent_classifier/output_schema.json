{
  "type": "object",
  "required": ["intent", "confidence", "reason", "requires_human_review", "safety_flags"],
  "properties": {
    "intent": {
      "type": "string",
      "enum": ["POLICY_ASSISTANCE", "LOAN_ASSESSMENT", "COLLECTIONS", "CONTROL_PLANE", "GENERAL_BANKING", "UNSUPPORTED"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "reason": { "type": "string" },
    "requires_human_review": { "type": "boolean" },
    "safety_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["prompt_injection", "pii_risk", "unsafe_sql", "regulatory_advice", "customer_harm", "out_of_scope", "none"]
      }
    }
  }
}
